# ============================================================
# GB10 AI Assistant – Configuration
# Copy this file to .env and adjust values to your needs
# ============================================================

# --- Model ---
MODEL_REPO=Qwen/Qwen3.6-35B-A3B-FP8
MODEL_DIR=/data/models/Qwen--Qwen3.6-35B-A3B-FP8
SERVED_MODEL_NAME=Qwen/Qwen3.6-35B-A3B-FP8

# --- vLLM ---
VLLM_IMAGE=nvcr.io/nvidia/vllm:26.05-py3
VLLM_PORT=8000
GPU_MEMORY_UTILIZATION=0.75
MAX_MODEL_LEN=262144
REASONING_PARSER=qwen3
TOOL_CALL_PARSER=qwen3_coder

# --- Open WebUI ---
OPEN_WEBUI_PORT=3000
WEBUI_SECRET_KEY=change-me-to-a-random-string

# --- Language (set automatically by setup.sh) ---
DEFAULT_LOCALE=

# --- SearXNG ---
SEARXNG_PORT=8080
SEARXNG_SECRET=change-me-to-another-random-string

# --- Hermes Agent (optional – only used by setup-hermes.sh) ---
HERMES_SKIP_BROWSER=true
